{
  "name": "shr-web-builder",
  "version": "0.1.0",
  "private": false,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "prebuild": "node scripts/run-builds.mjs",
    "content:sync": "node scripts/sync-content.mjs",
    "content:build": "npm run prebuild",
    "validate:results": "tsx scripts/validate-results.ts",
    "validate:results:content": "tsx scripts/validate-results.ts",
    "validate:results:strict": "tsx scripts/validate-results.ts --strict-filenames --warnings-as-errors",
    "dev": "next dev",
    "build": "npm run prebuild && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-virtual": "^3.13.24",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "csvtojson": "^2.0.14",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "next": "^16.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "csv-parse": "^5.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "tailwindcss": "^4",
    "tsx": "^4",
    "turndown": "^7.1.1",
    "typescript": "^5",
    "yaml": "^2.7.1"
  }
}
